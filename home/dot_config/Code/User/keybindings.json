// Place your key bindings in this file to override the defaults
[
  {
    "key": "ctrl+alt+n",
    "command": "workbench.action.tasks.runTask",
    "args": "Open in Neovim (project)"
  },
  // Ctrl + j/k keybindings (all tested) - up/down navigation in some windows
  {
    "key": "ctrl+j",
    "command": "list.focusDown",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "ctrl+k",
    "command": "list.focusUp",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "ctrl+j",
    "command": "workbench.action.quickOpenSelectNext",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+k",
    "command": "workbench.action.quickOpenSelectPrevious",
    "when": "inQuickOpen"
  },
  {
    "key": "ctrl+j",
    "command": "selectNextSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible"
  },
  {
    "key": "ctrl+k",
    "command": "selectPrevSuggestion",
    "when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible"
  },
  {
    "key": "ctrl+l",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "filesExplorerFocus"
  },
  {
    "key": "l",
    "command": "list.toggleExpand",
    "when": "listFocus && !inputFocus"
  },
  {
    "key": "ctrl+/",
    "command": "workbench.action.terminal.toggleTerminal",
    "when": "terminal.active"
  },
  {
    "key": "ctrl+`",
    "command": "-workbench.action.terminal.toggleTerminal",
    "when": "terminal.active"
  },
  {
    "key": "ctrl+j",
    "command": "-workbench.action.togglePanel"
  },
  // Other
  {
    "key": "ctrl+p",
    "command": "-workbench.action.quickOpen",
    "when": "terminalFocus"
  },
  {
    "key": "tab j",
    "command": "workbench.action.previousPanelView",
    "when": "panelFocus"
  },
  {
    "key": "tab k",
    "command": "workbench.action.nextPanelView",
    "when": "panelFocus"
  },
  {
    "key": "shift+h",
    "command": "workbench.action.previousPanelView",
    "when": "panelFocus"
  },
  {
    "key": "shift+l",
    "command": "workbench.action.nextPanelView",
    "when": "panelFocus"
  },
  {
    "key": "tab q",
    "command": "workbench.action.togglePanel",
    "when": "panelFocus"
  },
  {
    "key": "shift+l",
    "command": "workbench.action.nextSideBarView",
    "when": "sideBarFocus"
  },
  {
    "key": "shift+h",
    "command": "workbench.action.previousSideBarView",
    "when": "sideBarFocus"
  },
  // TODO: Tab + j/k doesn't work in "Python" side panel
  {
    "key": "tab j",
    "command": "workbench.action.previousSideBarView",
    "when": "sideBarFocus"
  },
  {
    "key": "tab k",
    "command": "workbench.action.nextSideBarView",
    "when": "sideBarFocus"
  },
  {
    "key": "space e",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "sideBarFocus"
  },
  {
    "key": "tab tab",
    "command": "workbench.action.toggleSidebarVisibility",
    "when": "sideBarFocus || panelFocus || auxiliaryBarFocus"
  },
  {
    "key": "tab space",
    "command": "workbench.action.togglePanel",
    "when": "sideBarFocus || panelFocus || auxiliaryBarFocus"
  },
  {
    "key": "tab enter",
    "command": "workbench.action.toggleAuxiliaryBar",
    "when": "sideBarFocus || panelFocus || auxiliaryBarFocus"
  },
  {
    "key": "escape",
    "command": "-notebook.cell.quitEdit",
    "when": "notebookEditorFocused && notebookOutputFocused"
  },
  // {
  // "key": "escape escape",
  // "command": "notebook.cell.quitEdit",
  // "when": "notebookEditorFocused && notebookOutputFocused"
  // },
  {
  "key": "escape",
  "command": "-notebook.cell.quitEdit",
  "when": "inputFocus && notebookEditorFocused && !editorHasMultipleSelections && !editorHasSelection && !editorHoverVisible && !inlineChatFocused"
  },
  {
    "key": "ctrl+q",
    "command": "-workbench.action.quit"
  },
  // {
  // "key": "escape escape",
  // "command": "notebook.cell.quitEdit",
  // "when": "inputFocus && notebookEditorFocused && !editorHasMultipleSelections && !editorHasSelection && !editorHoverVisible && !inlineChatFocused"
  // },
  // {
  // "key": "escape",
  // "command": "notebook.cell.quitEdit",
  // "when": "inputFocus && notebookEditorFocused && !editorHasMultipleSelections && !editorHasSelection && !editorHoverVisible && !inlineChatFocused && neovim.mode == 'insert'"
  // },
  // {
  // "key": "ctrl+o",
  // "command": "vscode-neovim.escape",
  // "when": "editorTextFocus && neovim.ctrlKeysInsert.o && neovim.init && neovim.mode == 'insert' && editorLangId not in 'neovim.editorLangIdExclusions'"
  // }
]