{{- if eq .machine "work_vm"             -}}
local env = "work"
{{- else if eq .machine "home_notebook"  -}}
local env = "home"
{{- end                                   }}

local environments = {}
environments.home = {}
    environments.home.wiki = {}
    environments.home.wiki.primary_wiki_path = '~/Desktop/Media/Documents/Wiki/IndexWiki/'
environments.work = {}
    environments.work.wiki = {}
    environments.work.wiki.primary_wiki_path = '~/Desktop/Media/Documents/Wiki/WorkWiki/'

return environments[env]

