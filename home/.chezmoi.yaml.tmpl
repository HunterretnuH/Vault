# Generated by chezmoi from .chezmoi.yaml.tmpl
{{- $machine := promptStringOnce . "machine" "Machine type (home_notebook/work_vm)" }}

diff:
  exclude:
    - scripts

data:
  machine: {{ $machine | quote }}
  packages:
{{- $pkgFile := joinPath .chezmoi.workingTree "machines" $machine "packages.yaml" -}}
{{- if stat $pkgFile }}
{{ include $pkgFile | indent 4 }}
{{- else }}
    {} # Fallback if packages.yaml is missing
{{- end }}

# TODO: Refactor hook loading mechanism to use templates and packages control variables
hooks:
  diff:
    pre:
{{- $hookPattern := joinPath .chezmoi.sourceDir ".hooks/diff-pre/*.yaml" -}}
{{- range (glob $hookPattern) }}
{{ include . | indent 6 }}
{{- end }}
