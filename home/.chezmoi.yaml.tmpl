# Generated by chezmoi from .chezmoi.yaml.tmpl
{{- $machine := promptStringOnce . "machine" "Machine type (home_notebook/work_vm)" }}

diff:
  exclude:
    - scripts

data:
  machine: {{ $machine | quote }}
  features:
{{- $pkgFile := joinPath .chezmoi.workingTree "machines" $machine "features.yaml" -}}
{{- if stat $pkgFile }}
{{ include $pkgFile | indent 4 }}
{{- else }}
    {} # Fallback if packages.yaml is missing
{{- end }}

hooks:
  diff:
    pre:
{{- $yamlPattern := joinPath .chezmoi.sourceDir ".hooks/diff-pre/*.yaml" -}}
{{- range (glob $yamlPattern) }}
{{ include . | indent 6 }}
{{- end }}
{{- $tmplPattern := joinPath .chezmoi.sourceDir ".hooks/diff-pre/*.yaml.tmpl" -}}
{{- range (glob $tmplPattern) }}
{{ includeTemplate . $ | indent 6 }}
{{- end }}
