[Unit]
Description=NAS Storage Share (TrueNAS)
OnFailure=automount-restarter@%N.service

[Mount]
What=//192.168.0.4/Storage
Where=/mnt/Remote/NAS/Storage
Type=cifs
Options=rw,credentials=/home/hunter/.smb-credentials/truenas-storage,uid=1000,gid=1000,iocharset=utf8,file_mode=0770,dir_mode=0770
TimeoutSec=30
