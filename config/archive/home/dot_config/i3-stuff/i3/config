#--1 Variables: mod keys, direction keys
    # MOD 1 - Super
    set $Mod2 Mod1
    set $Mod2 Mod1

    # MOD 2 - Alt
    set $Mod Mod4
    set $Mod Mod4

    # Primary Direction Keys
    set $up    k
    set $down  j
    set $left  h
    set $right l

    # Secondary Direction Keys
    set $up2    w
    set $down2  s
    set $left2  a
    set $right2 d

#--1 Default apps, exit menu, screen lock, shell config, help
