    #--2 WATCH
    alias wad="watch -n1 adb devices"
    #--2 WATCH FUNCTIONS
    alias wglogonline='watchGitLogOneline'
    alias wgstatus='watchGitStatus'
    alias wtree='watchTree'
#--1 FUNCTIONS
    #--2 WATCH WRAPPERS
    function watchGitStatus {
        while :
        do
            clear
            git status
            sleep 1
        done
    }

    function watchGitLogOneline {
        while :
        do
            clear
            git log --oneline
            sleep 1
        done
    }

    function watchTree {
        while :
        do
            clear
            tree -a
            sleep 1
        done
    }
#--1 FZF
    source ~/Programs/from_git/fzf/shell/key-bindings.bash #loads basic key-bindings
    source ~/Programs/from_git/fzf/shell/key-bindings.bash #enables completion like "cd ~/**<TAB>"

