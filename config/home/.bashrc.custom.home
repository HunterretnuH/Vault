    #--1 WIKI
        #--2 WIKI NEXTCLOUD DIFF
        WIKI_NEXTCLOUD_PATH=~/Nextcloud/Common/Wiki/

        alias wdn="WikiDiffLocalWithNextcloud"

        function WikiDiffLocalWithNextcloud {
            echo "Local Changes (not present on remote):"
            rsync -rnc --itemize-changes "$WIKI_PATH" "$WIKI_NEXTCLOUD_PATH"
            echo "Remote Changes (not present locally):"
            rsync -rnc --itemize-changes "$WIKI_NAS_PATH" "$WIKI_NEXTCLOUD_PATH"
        }

