    #--1 MSSH - My SSH 
    function mssh() {
        # My script for connecting to my devices using SSH
        mssh_path="/home/$USER/.ssh/mssh"
        filename=$(
            for file in "$mssh_path"/*; do
                helpline=$(head -n1 "$file")
                echo -e "$(basename "$file") $helpline"
            done | column -t -s '#' | fzf --border --height=30% | cut -d'#' -f1
        )
        source $mssh_path/$filename
    }

    #--1 OTHER - Consider removing
    #alias vrg="nvim --listen godothost ."
    #alias vrgn="cd ~/Documents/godot4-projects/Top-Down-2D-Game-Tutorial/;nvim --listen /tmp/godothost ."
    alias musb="udisksctl mount -b \$(echo /dev/\$(lsblk --list|grep -v -e nvme -e cryptlvm -e MyVolGroup|fzf|cut -d ' ' -f 1))"
