############################### MY BASHRC COMMON ################################

#####################    GLOBAL VARIABLES    #####################

#--1 XDG                - xdg SESSION_TYPE, config_home
    export XDG_CONFIG_HOME="$HOME/.config"
    export XDG_DATA_HOME="$HOME/.local/share"

#--1 LOCALE
    export LC_COLLATE=C

#--1 BASH CONFIG
    HISTCONTROL=ignoredups:erasedups # Avoid duplicates
    HISTSIZE=100000           # nr of history lines in memory
    HISTFILESIZE=100000       # nr of history lines loaded on shell startup or saved on shell close to/from file
    shopt -s histappend       # When the shell exits, append to the history file instead of overwriting it
#--1 TERMINAL CONFIG
    stty -ixon # FIX for mapping <C-q> in terminal

#--1 GENERAL            - PATH, GRAPHIC PROTOCOL, editor, screenshot dir, qt theme platform
    PATH=$MY_PROGRAMS_PATH/bin:/home/$USER/.local/bin:/home/$USER/.cargo/bin:$MY_SCRIPTS_PATH:$MY_SCRIPTS_PATH/not_used_directly:$PATH
    export EDITOR="nvim"
    export SCREENSHOT_DIR="$HOME/Pictures/Screenshots"
    export QT_QPA_PLATFORMTHEME=qt5ct


#--1 APP SPECIFIC       - ls colors, golang, firefox
    # COLORS FOR RANGER, LS AND FD
    export LS_COLORS=$LS_COLORS:'di=1;34'   # colors used by i.e. ls, ranger, fd

    # GOLANG
    export GOPATH="${MY_PROGRAMS_PATH}/go"

    # FIREFOX
    if [ "$XDG_SESSION_TYPE" = "wayland" ]; then
        export MOZ_ENABLE_WAYLAND=1
    fi

#++#++#++#++#++#++#++# END OF GLOBAL VARIABLES #++#++#++#++#++#++#++#

