################################# I3 CONFIG ##################################
# i3 config file (v4)
#--1 NWG-Shell managed settings:    i.e. outputs, workspaces, keyboard, mouse, some default apps
    # The files we include below will be created / overwritten by nwg-shell tools
    #include outputs
    include autostart
    include workspaces
#++

#####################    GENERAL SETTINGS    #####################
#--1 Appereance:                    wallpaper, borders, gaps, font
    #--2 Wallpaper
        exec --no-startup-id feh ~/Pictures/Wallpapers/fantasy-fox-landscape-tree-ay-2560x1080.jpg --bg-fill
        #exec ~/.azotebg
    #--2 Borders
        #for_window      [title="^.*"] border pixel 2, title_format "<b> %class >> %title </b>"
        default_border  pixel 2

        # Border colors:
        # class                 border  backgr. text    indicator child_border
        client.focused          #2855a3 #285590 #ffffff #2e9ef4   #2855a3
        client.focused_inactive #333333 #5f676a #ffffff #484e50   #5f676a
        client.unfocused        #333333 #222222 #888888 #292d2e   #222222
        client.urgent           #2f343a #900000 #ffffff #900000   #900000
        client.placeholder      #000000 #0c0c0c #ffffff #000000   #0c0c0c

        client.background       #ffffff

    #--2 Icons
        # enable window icons for all windows
        for_window [class=".*"] title_window_icon on

        # or enable window icons for all windows with extra horizontal padding
        #for_window [class=".*"] title_window_icon padding 3px

    #--2 Gaps
        #gaps        inner 7
        #gaps        outer 0
        #gaps        top 38

    #--2 Font
        font pango:NotoSans 11

#--1 Behaviour                      windows, gaps
    #--2 Windows
        # Set default split direction to split across y axis
        default_orientation             horizontal

        # Switch to workspacwe with urgent window
        for_window [urgent="latest"]    focus
        focus_on_window_activation      focus

        # Popup during fullscreen setting (smart - pop ups will appear only when they belong to fullscreen app)
        popup_during_fullscreen         smart

        #--3 Configuration of windows floating and borders for common apps and window names
            #for_window [app_id="(?i)(?:blueman-manager|azote|gnome-disks)"]                      floating enable
            #for_window [app_id="(?i)(?:pavucontrol|nm-connection-editor|gsimplecal|galculator)"] floating enable
            #for_window [app_id="(?i)(?:firefox|chromium)"]                                       border none
            for_window [title="(?i)(?:copying|deleting|moving)"]                                 floating enable

            # TODO: Verify these 2 below
            for_window [title="(?:Open|Save|Create) (?:File|Folder|As)"]                         floating enable;
            for_window [title="(?:Open|Save) (?:File|Folder|As)"]                                resize set 800 600

            # TODO: Verify these 2 below
            for_window [title="Desktop"] floating disable; border pixel 3

        #--3 Only for X11 Apps
            # TODO: Check if it works
            for_window [window_role="pop-up"] floating enable
            for_window [window_role="bubble"] floating enable
            for_window [window_role="task_dialog"] floating enable
            for_window [window_role="Preferences"] floating enable
            for_window [window_type="dialog"] floating enable
            for_window [window_type="menu"] floating enable

    #--2 Gaps
        #smart_gaps  on

#++#++#++#++#++#++#++# END OF GENERAL SETTINGS 

#########################    AUTOSTART   #########################
#--1 Some required stuff 
    #TODO: Check what exactly polkit is and why XDG_CURRENT DESKTOP WAS REMOVED
    #exec systemctl --user import-environment DISPLAY WAYLAND_DISPLAY SWAYSOCK
    #exec hash dbus-update-activation-environment 2>/dev/null && \
    #    dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK

    include /etc/sway/config.d/*
    exec /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

#++#++#++#++#++#++#++# END OF AUTOSTART

#####################    GENERAL BINDINGS    #####################
#--1 Variables: mod keys, direction keys
    # MOD 1 - Super
    set $Mod2 Mod4
    set $Mod2 Mod4

    # MOD 2 - Alt
    set $Mod Mod1
    set $Mod Mod1

    # Primary Direction Keys
    set $up    k
    set $down  j
    set $left  h
    set $right l

    # Secondary Direction Keys
    set $up2    w
    set $down2  s
    set $left2  a
    set $right2 d

#--1 Default apps, exit menu, screen lock, shell config, help
    set $term kitty
    set $browser firefox
    set $filemanager nemo
    set $editor kitty bash --rcfile ~/MyScripts/nvim_launcher.bashrc
    #set $launcher rofi -show run
    set $launcher rofi -i -show drun -show-icons -matching fuzzy -sort -sorting-method fzf

    set $opt fullscreen disable
    set $myWiki kitty --session=~/.config/kitty/sessions/kitty-wikivim.session 
    set $myKanban kitty --session=~/.config/kitty/sessions/kitty-kabmat.session
    set $myTasks kitty --session=~/.config/kitty/sessions/kitty-vit.session
    # Browser (TEMPORARY)
    # bindsym $Mod+b            $opt, exec $browser         
    # Dock (it could be used to launch apps from shortcut i.e. f, t)
    # bindsym $Mod+o            $opt, exec $dock            
    # bindsym $Mod+b            workspace name "Browser"
    # bindsym $Mod+f            workspace name "FileManager"
    # bindsym $Mod+v            workspace name "MyWiki"
    # bindsym $Mod+g            workspace name "Tasks"
    bindsym $Mod+Shift+Return scratchpad show
    # bindsym $Mod+Shift+b      move container to workspace name Browser;     workspace name Browser;
    # bindsym $Mod+Shift+f      move container to workspace name FileManager; workspace name FileManager
    # bindsym $Mod+Shift+v      move container to workspace name MyWiki;      workspace name MyWiki;
    # bindsym $Mod+Shift+t      move container to workspace name Tasks;       workspace name Tasks;

    # TODO: CREATE SEPARATE MODE for all TEMPORARY BINDINGS i.e. <leader>+e/<leader>+o
    # My Wiki (TEMPORARY)
    #bindsym $Mod+v            $opt, exec $myWiki          
    # File manager (TEMPORARY)
    #bindsym $Mod+f            $opt, exec $filemanager     
    # Notification manager
    # bindsym $Mod+n            $opt, exec swaync-client -t 
    # Kanban Board (TEMPORARY)
    #bindsym $Mod+g            $opt, exec $myKanban        
    # Kanban Board (TEMPORARY)
    #bindsym $Mod+t            $opt, exec $myTasks         
    # Application launcher
    bindsym $Mod+space        $opt, exec $launcher        
    bindsym $Mod+slash        $opt, exec rofi -i -show window -show-icons
    # Terminal
    bindsym $Mod+Return       $opt, exec $term
    # Lock screen
    # bindsym $Mod+Ctrl+l             exec nwg-lock         
    # Shell settings
    # bindsym $Mod+Ctrl+s             exec nwg-shell-config 
    # Toggle help display
    # bindsym $Mod+question           exec nwg-shell-help   

    # Kill focused window
    bindsym $Mod++q                 kill             
    # Exit menu
    mode "exit: [l]ogout, [r]eboot, [s]hutdown" {
      bindsym l exec i3-msg exit
      bindsym r exec systemctl reboot
      bindsym s exec systemctl shutdown
      bindsym Escape mode "default"
      bindsym Return mode "default"
    }
    bindsym $Mod+Ctrl+q mode "exit: [l]ogout, [r]eboot, [s]hutdown"
    # Reload the configuration file TODO: Check why "exec swaymsg..." is necessary
    bindsym $Mod+Ctrl+c             exec i3-msg reload   
    # Restart i3
    bindsym $Mod+Ctrl+r             exec swaymsg restart   

    ## Clipboard Screenshots
    bindsym Print           exec --no-startup-id maim | xclip -selection clipboard -t image/png
    bindsym Shift+Print     exec --no-startup-id maim --select | xclip -selection clipboard -t image/png
    bindsym Ctrl+Print      exec --no-startup-id maim --window $(xdotool getactivewindow) | xclip -selection clipboard -t image/png

#--1 Multimedia Keys
    # Audio
    bindsym XF86AudioPlay           exec playerctl play-pause
    bindsym XF86AudioNext           exec playerctl next
    bindsym XF86AudioPrev           exec playerctl previous
    bindsym XF86AudioStop           exec playerctl stop
    bindsym XF86AudioMute           exec pactl set-sink-mute @DEFAULT_SINK@ toggle
    bindsym XF86AudioRaiseVolume    exec pactl set-sink-volume @DEFAULT_SINK@ +5%
    bindsym XF86AudioLowerVolume    exec pactl set-sink-volume @DEFAULT_SINK@ -5%

    # Backlight
    bindsym XF86MonBrightnessUp     exec light -A 5
    bindsym XF86MonBrightnessDown   exec light -U 5

#--1 Mouse modifier
    # Drag/resize windows by holding down $mod and mouse button ( normal: left-drag, right-resize| inverse: opposite).
    floating_modifier $Mod

#++#++#++#++#++#++#++# END OF GENERAL BINDINGS

################    CONTAINER/WINDOW BINDINGS    #################
#--1 Move focus around:
    # Move focus to the parent container
    bindsym $Mod+p              focus parent
    bindsym $Mod+Shift+p        focus child

    # Swap focus between the tiling area and the floating area
    bindsym $Mod+f              focus mode_toggle

    # Change focus
    bindsym $Mod+$up            focus up
    bindsym $Mod+$down          focus down
    bindsym $Mod+$left          focus left
    bindsym $Mod+$right         focus right

    # Alternative change focus
    bindsym $Mod+$up2           focus up
    bindsym $Mod+$down2         focus down
    bindsym $Mod+$left2         focus left
    bindsym $Mod+$right2        focus right

    # Alternative change focus using arrow keys 
    bindsym $Mod+Up             focus up
    bindsym $Mod+Down           focus down
    bindsym $Mod+Left           focus left
    bindsym $Mod+Right          focus right


#--1 Move focused window/container around
    # Move focused window
    bindsym $Mod+Shift+$left    move left
    bindsym $Mod+Shift+$down    move down
    bindsym $Mod+Shift+$up      move up
    bindsym $Mod+Shift+$right   move right

    # Alternative move focused window
    bindsym $Mod+Shift+$up2     move up
    bindsym $Mod+Shift+$down2   move down
    bindsym $Mod+Shift+$left2   move left
    bindsym $Mod+Shift+$right2  move right

    # Alternative change focus using arrow keys 
    bindsym $Mod+Shift+Up       move up
    bindsym $Mod+Shift+Down     move down
    bindsym $Mod+Shift+Left     move left
    bindsym $Mod+Shift+Right    move right


#--1 Resizing windows/containers and gaps
    mode "resize" {
    #--2 Primary resize bindings
        # Primary resize bindings
        bindsym $Mod+$up        resize shrink   height  20 px or 5 ppt 
        bindsym $Mod+$down      resize grow     height  20 px or 5 ppt 
        bindsym $Mod+$left      resize shrink   width   20 px or 5 ppt 
        bindsym $Mod+$right     resize grow     width   20 px or 5 ppt 

        # Alternative primary resize bindings
        bindsym $Mod+$up2       resize shrink   height  20 px or 5 ppt 
        bindsym $Mod+$down2     resize grow     height  20 px or 5 ppt 
        bindsym $Mod+$left2     resize shrink   width   20 px or 5 ppt 
        bindsym $Mod+$right2    resize grow     width   20 px or 5 ppt 

        # Alternative primary resize bindings using arrow keys
        bindsym $Mod+Up        resize shrink   height  20 px or 5 ppt 
        bindsym $Mod+Down      resize grow     height  20 px or 5 ppt 
        bindsym $Mod+Left      resize shrink   width   20 px or 5 ppt 
        bindsym $Mod+Right     resize grow     width   20 px or 5 ppt 
        
    #--2 Secondary resize bindings
        # Secondary resize bindings
        bindsym $up             resize grow     up      20 px or 5 ppt 
        bindsym $down           resize grow     down    20 px or 5 ppt 
        bindsym $left           resize grow     left    20 px or 5 ppt 
        bindsym $right          resize grow     right   20 px or 5 ppt 
        bindsym Shift+$up       resize shrink   up      20 px or 5 ppt 
        bindsym Shift+$down     resize shrink   down    20 px or 5 ppt 
        bindsym Shift+$left     resize shrink   left    20 px or 5 ppt 
        bindsym Shift+$right    resize shrink   right   20 px or 5 ppt 

        # Alternative secondary resize bindings
        bindsym $up2            resize grow     up      20 px or 5 ppt 
        bindsym $down2          resize grow     down    20 px or 5 ppt 
        bindsym $left2          resize grow     left    20 px or 5 ppt 
        bindsym $right2         resize grow     right   20 px or 5 ppt 
        bindsym Shift+$up2      resize shrink   up      20 px or 5 ppt 
        bindsym Shift+$down2    resize shrink   down    20 px or 5 ppt 
        bindsym Shift+$left2    resize shrink   left    20 px or 5 ppt 
        bindsym Shift+$right2   resize shrink   right   20 px or 5 ppt 

        # Alternative secondary resize bindings using arrow keys
        bindsym up              resize grow     up      20 px or 5 ppt 
        bindsym down            resize grow     down    20 px or 5 ppt 
        bindsym left            resize grow     left    20 px or 5 ppt 
        bindsym right           resize grow     right   20 px or 5 ppt 
        bindsym Shift+up        resize shrink   up      20 px or 5 ppt 
        bindsym Shift+down      resize shrink   down    20 px or 5 ppt 
        bindsym Shift+left      resize shrink   left    20 px or 5 ppt 
        bindsym Shift+right     resize shrink   right   20 px or 5 ppt 

    #--2 Resize gaps
        # Resize outer gaps
        bindsym equal               gaps inner current plus  5
        bindsym minus               gaps inner current minus 5
        bindsym 0                   gaps inner current set   0

        # Resize inner gaps
        bindsym Shift+equal         gaps outer current plus  5
        bindsym Shift+minus         gaps outer current minus 5
        bindsym Shift+0             gaps outer current set   0

    #--2 Return to default mode and resize mode binding
        bindsym Return              mode "default"
        bindsym Escape              mode "default"
        bindsym $Mod+r              mode "default"

    }
    bindsym $Mod+r                  mode "resize"
    
#--1 Change windows/containers layout and properties i.e. floating, borders, fullscreen, sticky
    # Cycle through layouts
    bindsym $Mod+c              layout toggle tabbed stacking split

    # Toggle border style
    bindsym $Mod+Shift+c        border toggle

    # Select split direction (split across x or y axis)
    bindsym $Mod+x              split v
    bindsym $Mod+y              split h

    # Select split layout direction (split across x or y axis)
    bindsym $Mod+Shift+x        layout splitv
    bindsym $Mod+Shift+y        layout splith

    # Toggle floating
    bindsym $Mod+Shift+f        floating toggle

    # Toggle fullscreen
    bindsym $Mod+m              fullscreen toggle

    # Always on top toggle
    bindsym $Mod+Shift+i        sticky toggle

#++#++#++#++#++#++#++# END OF CONTAINER/WINDOW BINDINGS

