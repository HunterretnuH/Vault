
configuration {
    kb-row-up: "Up,Control+k";
    kb-row-down: "Down,Control+j";
  	kb-accept-entry: "Control+m,Return,KP_Enter";
  	kb-remove-to-eol: "";
}

window {
    width: 800;
}

element-icon {
    size: 2em;
}

//THEME
configuration {
    font: "Noto Sans 18";
    line-margin: 10;

    display-ssh:    "";
    display-run:    "";
    display-drun:   "";
    display-window: "";
    display-combi:  "";
    show-icons:     true;
}


@theme "~/.config/rofi/nord.rasi"

listview {
	lines: 7;
	columns: 1;
}

window {
	width: 40%;
}
